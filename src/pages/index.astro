---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionMenu from '../components/SectionMenu.astro';
import { services } from '../data/services';
import headshot from '../assets/photos/headshot.jpeg';
---

<BaseLayout
  title="Derek Dombek — Infrastructure & DevOps for Small Businesses"
  description="I bring enterprise-grade infrastructure reliability to small businesses — your website and tools hosted, automated, backed up, and monitored so they never silently break."
>
  <section class="hero hero-lead">
    <Image class="headshot" src={headshot} alt="Portrait of Derek Dombek" width={240} height={240} />
    <h1>Automate the Earth.</h1>
    <p class="hero-sub">
      I Deploy, fix, back up, monitor and automate your website and workflows — so you don't have to worry about them so much..
    </p>
    <div class="hero-cta">
      <a class="btn btn-accent" href="/contact/">Book a free audit</a>
      <a class="btn" href="/services/">See what I do</a>
    </div>
    <hr class="rule" />
  </section>

  <section class="home-services">
    {services.map((s) => (
      <a class="home-service" href={`/services/#${s.slug}`}>
        <h3>{s.name}</h3>
        <p>{s.tagline}</p>
      </a>
    ))}
  </section>

  <SectionMenu />
</BaseLayout>
